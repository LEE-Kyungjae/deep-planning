{
  "version": "v1",
  "actions": [
    {
      "action": "update_plan",
      "description": "Apply top-level plan changes and return an integrated cycle snapshot.",
      "required_capabilities": ["plan.write"],
      "payload_required": false,
      "payload_keys": ["goal", "success_metric", "deadline", "planning_horizon", "review_cadence", "selected_option"],
      "options": ["expected_fingerprint", "allow_retry", "require_healthy", "history_limit"]
    },
    {
      "action": "capture_evidence_cycle",
      "description": "Append evidence, run replan, and return the post-cycle snapshot.",
      "required_capabilities": ["evidence.append_and_replan"],
      "payload_required": true,
      "payload_keys": ["evidence", "replan", "idempotency_key"],
      "options": ["expected_fingerprint", "allow_retry", "require_healthy", "history_limit"]
    },
    {
      "action": "run_reference_discovery",
      "description": "Generate and optionally apply a structured reference-discovery pass.",
      "required_capabilities": ["reference.discover"],
      "payload_required": true,
      "payload_keys": ["question", "context", "references", "rejected", "apply"],
      "options": ["expected_fingerprint", "history_limit"]
    },
    {
      "action": "request_review",
      "description": "Open a human-review escalation and return an integrated cycle snapshot.",
      "required_capabilities": ["review.request"],
      "payload_required": true,
      "payload_keys": ["scope", "reason", "requested_by", "review_recommendation", "review_reason", "related_evidence", "related_references"],
      "options": ["expected_fingerprint", "allow_retry", "require_healthy", "history_limit"]
    },
    {
      "action": "resolve_review",
      "description": "Resolve, dismiss, or acknowledge an existing human-review escalation and return an integrated cycle snapshot.",
      "required_capabilities": ["review.resolve"],
      "payload_required": true,
      "payload_keys": ["request_id", "status", "resolution", "resolved_by", "review_recommendation", "review_reason"],
      "options": ["expected_fingerprint", "allow_retry", "require_healthy", "history_limit"]
    },
    {
      "action": "preview_restore_previous",
      "description": "Preview restoring the previous revision without mutating plan state.",
      "required_capabilities": ["plan.read"],
      "payload_required": false,
      "payload_keys": [],
      "options": []
    },
    {
      "action": "restore_previous",
      "description": "Restore the previous revision and return an integrated cycle snapshot.",
      "required_capabilities": ["plan.restore"],
      "payload_required": false,
      "payload_keys": [],
      "options": ["expected_fingerprint", "allow_retry", "require_healthy", "history_limit"]
    },
    {
      "action": "evaluate_experience_strategy",
      "description": "Evaluate whether an idea has strong problem-solution, desire, experience-loop, monetization, differentiation, and reference-insight structure.",
      "required_capabilities": ["plan.read", "strategy.evaluate"],
      "payload_required": true,
      "payload_keys": ["idea", "entry_mode", "project_stage", "existing_artifacts", "pivot_signals", "target_user", "problem", "current_alternative", "pain_frequency", "solution", "desire", "emotion", "trigger", "action", "reward", "references", "behavior_signals", "monetization", "repeat_loop", "differentiation", "personal_profile"],
      "options": ["history_limit"]
    },
    {
      "action": "generate_creative_directions",
      "description": "Use AI to transform references, behavior signals, and personal planning profile into non-generic product directions for new or mid-project planning.",
      "required_capabilities": ["plan.read", "strategy.generate"],
      "payload_required": true,
      "payload_keys": ["topic", "entry_mode", "project_stage", "existing_artifacts", "current_plan", "constraints", "pivot_signals", "references", "behavior_signals", "success_cases", "failure_cases", "papers", "reviews", "personal_profile"],
      "options": ["history_limit"]
    }
  ],
  "profiles": {
    "planner_full": {
      "capabilities": ["plan.read", "plan.write", "evidence.append_and_replan", "review.request", "review.resolve", "plan.restore"],
      "allowed_actions": ["update_plan", "capture_evidence_cycle", "request_review", "resolve_review", "preview_restore_previous", "restore_previous"]
    },
    "strategist_product": {
      "capabilities": ["plan.read", "strategy.evaluate", "strategy.generate", "review.request"],
      "allowed_actions": ["evaluate_experience_strategy", "generate_creative_directions", "request_review", "preview_restore_previous"]
    },
    "researcher_capture": {
      "capabilities": ["plan.read", "evidence.append_and_replan", "reference.discover", "review.request"],
      "allowed_actions": ["capture_evidence_cycle", "run_reference_discovery", "request_review", "preview_restore_previous"]
    },
    "reviewer_restore": {
      "capabilities": ["plan.read", "review.request", "review.resolve", "plan.restore"],
      "allowed_actions": ["request_review", "resolve_review", "preview_restore_previous", "restore_previous"]
    }
  },
  "role_profiles": {
    "planner": "planner_full",
    "strategist": "strategist_product",
    "researcher": "researcher_capture",
    "reviewer": "reviewer_restore"
  }
}
